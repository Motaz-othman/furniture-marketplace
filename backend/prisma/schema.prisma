generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ShipmentProvider {
  DELIVERIGHT
  GIGIGA
  FEDEX
  UPS
  OTHER
}

enum ShipmentType {
  LTL
  SMALL_PARCEL
}

enum ShipmentStatus {
  PENDING
  QUOTED
  ARRANGED
  IN_TRANSIT
  DELIVERED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  isBlocked             Boolean   @default(false)
  firstName    String
  lastName     String
  phone        String?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resetPasswordToken    String?   @unique
  resetPasswordExpires  DateTime?
  tokenVersion          Int       @default(0)
  notifications  Notification[]
  
  customer     Customer?
  
  @@index([email])
}

model Customer {
  id               String     @id @default(uuid())
  userId           String     @unique
  stripeCustomerId String?
  
  user             User       @relation(fields: [userId], references: [id])
  cartItems        CartItem[]
  addresses        Address[]
  orders           Order[]
  reviews          Review[]  
  wishlist       Wishlist[] 
  
  @@index([userId])
}

model Address {
  id         String    @id @default(uuid())
  customerId String?
  label      String?
  street     String
  city       String
  state      String
  zipCode    String
  country    String    @default("US")
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())

  customer   Customer? @relation(fields: [customerId], references: [id])
  orders     Order[]

  @@index([customerId])
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  storefrontListings StorefrontListing[]

  @@index([parentId])
  @@index([sortOrder])
}

model Product {
  id              String      @id @default(uuid())
  categoryId      String?
  name            String
  slug            String      @unique
  description     String
  brand           String?
  collection      String?
  provider        String?

  // Category paths from provider [{imageUrl, path}]
  categories      Json?

  // Media: {mainImages, additionalImages, videoUrls} each with [{url, variantProductIds}]
  media           Json?

  // Related products: {completeYourCollection, crossSell, series} arrays of product IDs
  relatedProducts Json?

  // The attribute key that differentiates variants (e.g. "color", "size")
  variantKey      String?

  // Computed fields (set during Wondersign sync)
  minPrice        Float?      // lowest variant retailPrice
  maxPrice        Float?      // highest variant retailPrice
  compareAtPrice  Float?      // max variant msrpPrice (for sale strikethrough)
  totalStock      Int         @default(0) // sum of all variant stockQuantities
  mainImage       String?     // first mainImages[0].url from media

  // Storefront flags
  isFeatured      Boolean     @default(false)
  isNew           Boolean     @default(false)
  isOnSale        Boolean     @default(false)
  isActive        Boolean     @default(true)

  // Aggregated ratings
  rating          Float?      @default(0)
  totalReviews    Int         @default(0)

  // Sync tracking
  source          String      @default("MANUAL")
  externalId      String?
  externalData    Json?
  lastSyncAt      DateTime?
  acmeStatus      String?     // 'ACTIVE' | 'DISABLED' | 'REMOVED' — populated for source='ACME' only

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  category        Category?   @relation(fields: [categoryId], references: [id])
  cartItems       CartItem[]
  orderItems      OrderItem[]
  reviews         Review[]
  wishlistItems   Wishlist[]
  variants        ProductVariant[]
  storefront      StorefrontListing?

  @@index([categoryId])
  @@index([name])
  @@index([slug])
  @@index([isFeatured])
  @@index([isNew])
  @@index([isOnSale])
  @@index([brand])
  @@index([collection])
  @@index([isActive])
  @@index([acmeStatus])
  @@unique([externalId, source])
  @@index([source])
}

model CartItem {
  id         String   @id @default(uuid())
  customerId String
  productId  String
  variantId  String?
  quantity   Int      @default(1)
  addedAt    DateTime @default(now())

  customer   Customer        @relation(fields: [customerId], references: [id])
  product    Product         @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([customerId, productId, variantId])
  @@index([customerId])
}
model Order {
  id              String      @id @default(uuid())
  customerId      String?
  addressId       String
  orderNumber     String      @unique
  status          OrderStatus @default(PENDING)
  subtotal        Float
  tax             Float       @default(0)
  shippingCost    Float       @default(0)
  total           Float
  stripePaymentId String?
  trackingNumber  String?
  trackingUrl     String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  source                String        @default("DIRECT")
  externalOrderId       String?
  externalData          Json?
  stripePaymentIntentId String?
  paymentStatus         PaymentStatus @default(PENDING)

  // Guest checkout fields
  guestEmail      String?
  guestFirstName  String?
  guestLastName   String?
  guestPhone      String?

  customer              Customer?     @relation(fields: [customerId], references: [id])
  address               Address       @relation(fields: [addressId], references: [id])
  items                 OrderItem[]
  shipments             Shipment[]

  @@index([customerId])
  @@index([orderNumber])
  @@index([source])
  @@index([externalOrderId])
  @@index([guestEmail])
}


model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  shipmentId String?
  productId  String
  variantId  String?
  quantity   Int
  price      Float

  order    Order           @relation(fields: [orderId], references: [id])
  shipment Shipment?       @relation(fields: [shipmentId], references: [id])
  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([shipmentId])
}

model Shipment {
  id             String            @id @default(uuid())
  orderId        String
  provider       ShipmentProvider?
  type           ShipmentType?
  status         ShipmentStatus    @default(PENDING)
  estimatedCost  Float?
  actualCost     Float?
  trackingNumber String?
  trackingUrl    String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  order Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([orderId])
}

model Review {
  id         String   @id @default(uuid())
  productId  String
  customerId String
  rating     Int      // 1-5 stars
  comment    String?
  createdAt  DateTime @default(now())
  
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@unique([productId, customerId])
  @@index([productId])
  @@index([customerId])
}

model Wishlist {
  id         String   @id @default(uuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())
  
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([customerId, productId])
  @@index([customerId])
  @@index([productId])
}
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 'ORDER_PLACED', 'ORDER_STATUS_CHANGED', 'PRODUCT_REVIEWED', etc.
  title     String
  message   String
  data      Json?    // Extra data (orderId, productId, etc.)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

model ProductVariant {
  id                  String      @id @default(uuid())
  productId           String

  // Basic info
  name                String?
  description         String?
  consumerBrand       String?
  productType         String?

  // Identifiers
  sku                 String?     @unique
  customerSku         String?
  upc                 String?
  externalProductId   String?     @unique // productId from provider (e.g. "CSS191826756")

  // Status
  status              String      @default("Active")  // Active, Discontinued, etc.
  changedState        String?     // "created", "updated", "deleted" — variant lifecycle from provider
  isActive            Boolean     @default(true)
  isDirectShipping    Boolean     @default(false)
  isInCatalog         String?     @default("included") // "included", "excluded"
  isPackage           Boolean     @default(false)
  isSoldIndividually  Boolean     @default(true)

  // Price: {cost, listPrice, mapPrice, msrpPrice, retailPrice, rates[], rentalPrices[]}
  price               Json

  // Physical attributes
  dimensions          Json?       // {height, length, width, weight, unitOfMeasureDistance, unitOfMeasureWeight}
  packaging           Json?       // {dimensions, dimensionsUnitOfMeasure, weight, weightUnitOfMeasure, type, ...}

  // Variant attributes & options
  attributes          Json?       // [{attribute, normalizedValues[], values[]}]
  options             Json?       // [{option, value}]
  categories          Json?       // [{imageUrl, path}]

  // Package info
  packageProducts     Json?       // [{optional, quantity, productId, sku}]
  packageProductType  String?     // "kit", "bundle", etc.

  // Stock
  stockQuantity       Int         @default(0)

  // Display order
  rank                Int         @default(0)

  // Custom data from provider
  custom              Json?

  // Timestamps
  introducedAt        DateTime?
  deletedAt           DateTime?   // soft delete
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  product             Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems           CartItem[]
  orderItems          OrderItem[]

  @@index([productId])
  @@index([status])
  @@index([sku])
  @@index([externalProductId])
}

model StorefrontListing {
  id                  String    @id @default(uuid())
  productId           String    @unique

  // Display overrides (null = use raw Product data)
  displayName         String?
  displayDescription  String?
  displayImages       Json?       // custom image array override

  // Pricing (null = use raw Wondersign price)
  displayPrice        Float?      // Original price (product-level override)
  discountedPrice     Float?      // Sale/discounted price (null = no discount)
  compareAtPrice      Float?      // legacy strikethrough price
  pricingRule         Json?       // e.g. {"type": "markup", "percentage": 30}
  variantPrices       Json?       // per-variant price overrides: { "variantId": price }

  // Stock override (null = use raw Wondersign totalStock)
  displayStock        Int?        // product-level stock override
  variantStocks       Json?       // per-variant stock overrides: { "variantId": qty }

  // Storefront category (may differ from Wondersign's category)
  categoryId          String?

  // Storefront flags
  isPublished         Boolean     @default(false)
  isOnSale            Boolean     @default(false)
  isTrending          Boolean     @default(false)
  isNewArrival        Boolean     @default(false)
  sortOrder           Int         @default(0)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  product             Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  category            Category?   @relation(fields: [categoryId], references: [id])

  @@index([isPublished])
  @@index([isOnSale])
  @@index([isTrending])
  @@index([isNewArrival])
  @@index([categoryId])
  @@index([sortOrder])
}

model IntegrationProvider {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  type          String
  apiKey        String?
  apiSecret     String?
  isActive      Boolean   @default(false)
  settings      Json?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  syncLogs      SyncLog[]
}

model SyncLog {
  id            String    @id @default(uuid())
  source        String
  type          String
  status        String
  itemsTotal    Int       @default(0)
  itemsSynced   Int       @default(0)
  itemsFailed   Int       @default(0)
  errors        Json?
  data          Json?
  createdAt     DateTime  @default(now())

  providerId    String?
  provider      IntegrationProvider? @relation(fields: [providerId], references: [id])

  @@index([source])
  @@index([type])
  @@index([createdAt])
}

model SiteSettings {
  id        String   @id @default("main")
  settings  Json     @default("{}")
  updatedAt DateTime @updatedAt
}
model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  subscribedAt DateTime @default(now())

  @@index([email])
}
